' ============================================================================

Public Enum FrameTypes3D
    ''' <summary>Velocity magnitude squared (ux^2 + uy^2 + uz^2)</summary>
    Speed
    ''' <summary>Macroscopic density rho</summary>
    Density
    ''' <summary>X-component of velocity</summary>
    XVel
    ''' <summary>Y-component of velocity</summary>
    YVel
    ''' <summary>Z-component of velocity</summary>
    ZVel
End Enum
